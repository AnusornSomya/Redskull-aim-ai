<UserControl x:Class="Redskull.Controls.SinglePageMenuControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="720">
    <ScrollViewer x:Name="SinglePageScrollViewerControl"
                  VerticalScrollBarVisibility="Auto"
                  PanningMode="VerticalOnly">
        <StackPanel Margin="14,14,14,18">
            <Border Margin="0,0,0,16"
                    Padding="18"
                    CornerRadius="16"
                    BorderBrush="#44FFFFFF"
                    BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="#AA541A16"
                                      Offset="0" />
                        <GradientStop Color="#663B1110"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Margin="0,0,0,14">
                        <TextBlock Text="โมเดล AI"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   FontFamily="{StaticResource Atkinson Hyperlegible}" />
                        <TextBlock Text="ค่าเริ่มต้นจะใช้ 1.5kR6.onnx และสามารถเปลี่ยนได้ด้วยการนำเข้าไฟล์ .onnx"
                                   Margin="0,6,0,0"
                                   Foreground="#D9FFFFFF"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   FontFamily="{StaticResource Atkinson Hyperlegible}" />
                    </StackPanel>

                    <ComboBox x:Name="ModelSelector"
                              Grid.Row="1"
                              Grid.Column="0"
                              Height="38"
                              Margin="0,0,12,0"
                              Padding="8,0,8,0"
                              Foreground="White"
                              BorderBrush="#55FFFFFF"
                              BorderThickness="1"
                              Background="#223C3C3C"
                              FontFamily="{StaticResource Atkinson Hyperlegible}"
                              SelectionChanged="ModelSelector_SelectionChanged">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground"
                                        Value="Black" />
                                <Setter Property="FontFamily"
                                        Value="{StaticResource Atkinson Hyperlegible}" />
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <Button x:Name="ImportModelButton"
                            Grid.Row="1"
                            Grid.Column="1"
                            Height="38"
                            Margin="0,0,10,0"
                            Padding="16,0"
                            Click="ImportModelButton_Click"
                            Background="#FFDC2626"
                            BorderBrush="#00FFFFFF"
                            Foreground="White"
                            FontFamily="{StaticResource Atkinson Hyperlegible}"
                            FontWeight="Bold"
                            Content="นำเข้าโมเดล"
                            materialDesign:ButtonAssist.CornerRadius="10" />

                    <Button x:Name="OpenModelsFolderButton"
                            Grid.Row="1"
                            Grid.Column="2"
                            Height="38"
                            Padding="16,0"
                            Click="OpenModelsFolderButton_Click"
                            Background="#223C3C3C"
                            BorderBrush="#55FFFFFF"
                            BorderThickness="1"
                            Foreground="White"
                            FontFamily="{StaticResource Atkinson Hyperlegible}"
                            Content="เปิดโฟลเดอร์"
                            materialDesign:ButtonAssist.CornerRadius="10" />

                    <Border x:Name="ModelDropZone"
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Margin="0,14,0,0"
                            Padding="14"
                            Background="#14202020"
                            BorderBrush="#44FFFFFF"
                            BorderThickness="1"
                            CornerRadius="12"
                            AllowDrop="True"
                            DragOver="ModelDropZone_DragOver"
                            Drop="ModelDropZone_Drop">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="ลากไฟล์โมเดล .onnx มาวางที่นี่"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           FontFamily="{StaticResource Atkinson Hyperlegible}" />
                                <TextBlock Text="โมเดลที่โหลดอยู่ตอนนี้"
                                           Margin="0,6,0,0"
                                           Foreground="#C8FFFFFF"
                                           FontSize="11"
                                           FontFamily="{StaticResource Atkinson Hyperlegible}" />
                            </StackPanel>

                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Padding="12,6"
                                    Background="#22FFFFFF"
                                    BorderBrush="#44FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                <TextBlock x:Name="CurrentModelText"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           FontFamily="{StaticResource Atkinson Hyperlegible}"
                                           Text="ยังไม่ได้โหลดโมเดล" />
                            </Border>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.94*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="1.06*" />
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="LeftColumn"
                            Grid.Column="0" />

                <StackPanel x:Name="RightColumn"
                            Grid.Column="2" />
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>

