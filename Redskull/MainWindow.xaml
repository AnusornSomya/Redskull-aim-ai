<Window x:Class="Redskull.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Ant="clr-namespace:AntWpf.Controls;assembly=AntWpf"
        xmlns:controls="clr-namespace:Redskull.Controls"
        xmlns:theme="clr-namespace:Redskull.Theme"
        theme:ThemeBehavior.AutoRegister="True"
        mc:Ignorable="d"
        Title="REDSKULL AIM AI"
        Icon="/Assets/icon.ico"
        Height="820"
        MinHeight="720"
        Width="760"
        MinWidth="720"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Closing="Window_Closing"
        Loaded="Window_Loaded">
    <Window.Resources>
        <!-- Theme colors that can be updated dynamically -->
        <SolidColorBrush x:Key="ThemeColor" Color="#FFDC2626"/>
        <SolidColorBrush x:Key="ThemeColorDark" Color="#FF991B1B"/>
        <SolidColorBrush x:Key="ThemeColorLight" Color="#FFEF4444"/>
        <SolidColorBrush x:Key="ThemeGradientDark" Color="#FF3B0A0A"/>

        <!-- Additional theme variations -->
        <SolidColorBrush x:Key="ThemeColorTransparent" Color="#33DC2626"/>
        <SolidColorBrush x:Key="ThemeColorSemiTransparent" Color="#66DC2626"/>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="2"
                      CaptionHeight="0" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Border x:Name="MainBorder"
                CornerRadius="5,5,5,5"
                BorderBrush="Black"
                BorderThickness="1,1,1,1"
                MouseMove="Main_Background_Gradient">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1"
                                     StartPoint="0,0">
                    <LinearGradientBrush.RelativeTransform>
                        <TransformGroup>
                            <ScaleTransform CenterY="0.5"
                                            CenterX="0.5" />
                            <SkewTransform CenterX="0.5"
                                           CenterY="0.5" />
                            <RotateTransform x:Name="RotaryGradient"
                                             Angle="0"
                                             CenterX="0.5"
                                             CenterY="0.5" />
                            <TranslateTransform />
                        </TransformGroup>
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Color="Black"
                                  Offset="0.27" />
                    <GradientStop x:Name="GradientThemeStop" 
                                  Color="#FF3B0A0A"
                                  Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid x:Name="Topbar"
                      VerticalAlignment="Top"
                      Height="56">
                    <Image x:Name="RedskullLogo"
                           Source="/Assets/icon.ico"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Width="22"
                           Height="22"
                           Margin="14,0,0,0"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <Label Content="REDSKULL AIM AI"
                           HorizontalAlignment="Left"
                           Margin="48,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#DDFFFFFF"
                           Padding="0,0,0,0"
                           FontSize="14"
                           FontFamily="{StaticResource Atkinson Hyperlegible}" />
                    <Label Content="Single Page Control"
                           HorizontalAlignment="Left"
                           Margin="0,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#99FFFFFF"
                           Padding="0,0,0,0"
                           FontSize="11"
                           FontFamily="{StaticResource Atkinson Hyperlegible}"
                           Visibility="Collapsed" />
                    <Button x:Name="Exit"
                            Content="&#xE8BB;"
                            HorizontalAlignment="Right"
                            Background="{x:Null}"
                            BorderBrush="{x:Null}"
                            Foreground="White"
                            FontFamily="Segoe MDL2 Assets"
                            Padding="15,0,15,0"
                            materialDesign:ButtonAssist.CornerRadius="0,5,5,0"
                            BorderThickness="0,0,0,0"
                            FontSize="10"
                            VerticalAlignment="Center"
                            Click="Exit_Click" />
                    <Button x:Name="Minimize"
                            Content="&#xE921;"
                            HorizontalAlignment="Right"
                            Background="{x:Null}"
                            BorderBrush="{x:Null}"
                            Foreground="White"
                            FontFamily="Segoe MDL2 Assets"
                            Padding="15,0,15,0"
                            materialDesign:ButtonAssist.CornerRadius="5,0,0,5"
                            BorderThickness="0,0,0,0"
                            FontSize="10"
                            VerticalAlignment="Center"
                            Click="Minimize_Click"
                            Margin="0,0,40,0" />
                </Grid>
                <Grid x:Name="ContentArea"
                      Margin="0,56,0,0" />
            </Grid>
        </Border>
    </Grid>
</Window>

